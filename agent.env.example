# Variables de l'AGENT (à copier en .env sur ton PC — NE JAMAIS committer).
# Mêmes valeurs que le stack web pour les partagées (Mongo, VAULT_KEY, EDJ, NOTIFY).

# Base (identique au web)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=skan

# Coffre (DOIT être identique à la VAULT_KEY du web, sinon déchiffrement impossible)
VAULT_KEY=

# Notifications EDJ Labs (identiques au web)
EDJ_API_BASE=https://api.edj-labs.com
EDJ_SMS_TOKEN=
EDJ_WA_TOKEN=
EDJ_EMAIL_TOKEN=
EDJ_EMAIL_ENDPOINT=https://api.edj-labs.com/email/send
NOTIFY_PHONE=+33000000000
NOTIFY_EMAIL=change-me@example.com

# Canaux + URL publique (pour les liens GO dans les SMS)
ENABLED_CHANNELS=sms,whatsapp,email
PUBLIC_APP_URL=https://skan.nmt.ovh

# iBail : email de connexion (magic link envoyé dessus)
IBAIL_EMAIL=nicolas.monniot14@gmail.com

# Lecture des magic links (Gmail app password — cf. README)
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_IMAP_USER=nicolas.monniot14@gmail.com
GMAIL_IMAP_APP_PASSWORD=

# Assistance IA (optionnel)
LLM_PROXY_URL=
LLM_PROXY_KEY=
