# ── Base de données ───────────────────────────────────────────────
# URI MongoDB Atlas (whitelister l'IP EDJ Labs dans Network Access)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=skan

# ── API de notification EDJ Labs ──────────────────────────────────
EDJ_API_BASE=https://api.edj-labs.com
# Tokens (X-Api-Token) — à récupérer dans le dashboard EDJ Labs.
# NE JAMAIS committer les vraies valeurs : injecter via le stack EDJ Labs.
EDJ_SMS_TOKEN=
EDJ_WA_TOKEN=
EDJ_EMAIL_TOKEN=
# Endpoint email EDJ Labs (corps : { recipients:[...], subject, html })
EDJ_EMAIL_ENDPOINT=https://api.edj-labs.com/email/send

# ── Destinataires des alertes ─────────────────────────────────────
NOTIFY_PHONE=+33000000000
NOTIFY_EMAIL=change-me@example.com

# ── Comportement ──────────────────────────────────────────────────
# Canaux actifs (séparés par des virgules) : sms,whatsapp,email
ENABLED_CHANNELS=sms,whatsapp,email
# Fréquence du polling en minutes
POLL_INTERVAL_MIN=5
# Secret pour protéger POST /api/cron/check
CRON_SECRET=change-me-long-random-string

# ── Auth de l'app (OBLIGATOIRE avant d'utiliser le coffre/settings) ──
# Générer le hash : npm run hash-password -- 'ton-mot-de-passe'
AUTH_PASSWORD_HASH=
# Chaîne aléatoire longue (openssl rand -hex 32) — signe les cookies de session
AUTH_SECRET=

# ── Coffre chiffré (données candidature auto-apply) ──────────────
# Clé AES-256 : 64 caractères hex (openssl rand -hex 32). NE JAMAIS la perdre :
# elle déchiffre les données garants/dossier. Jamais dans le repo.
VAULT_KEY=

# ── Agent d'auto-candidature (service skan-agent uniquement) ─────
# URL publique (pour construire les liens GO dans les SMS)
PUBLIC_APP_URL=https://skan.nmt.ovh
# Email de connexion iBail (magic link envoyé dessus)
IBAIL_EMAIL=
# Lecture des magic links par IMAP (Gmail app password — voir README)
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_IMAP_USER=
GMAIL_IMAP_APP_PASSWORD=

# ── Assistance IA optionnelle (proxy perso) ──────────────────────
LLM_PROXY_URL=
LLM_PROXY_KEY=

# ── Runtime ───────────────────────────────────────────────────────
PORT=3000
HOSTNAME=0.0.0.0
